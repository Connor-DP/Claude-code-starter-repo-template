{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Agent"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=\"$CLAUDE_TOOL_PARAM_file_path\"; if [[ \"$FILE\" =~ \\.(ts|tsx|js|jsx)$ ]] && command -v npx &>/dev/null && [ -f package.json ]; then npx eslint --fix \"$FILE\" 2>/dev/null || true; fi'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=\"$CLAUDE_TOOL_PARAM_command\"; if echo \"$CMD\" | grep -qE \"rm\\s+-rf\\s+/|DROP\\s+TABLE|DROP\\s+DATABASE\"; then echo \"BLOCKED: Destructive command detected. Review manually.\" >&2; exit 2; fi'"
          }
        ]
      }
    ]
  },

  "contextManagement": {
    "maxTokens": 200000,
    "priorityFiles": [
      "CLAUDE.md",
      "IMPLEMENTATION_PLAN.md",
      "CHECKLIST.md",
      "ai/DEFINITIONS/DONE_DEFINITION.md"
    ],
    "ignoredPaths": [
      "node_modules/**",
      "venv/**",
      "target/**",
      "dist/**",
      "build/**",
      "coverage/**",
      ".cache/**",
      "*.log",
      "*.tmp",
      "*.lock",
      "package-lock.json",
      "yarn.lock",
      "Cargo.lock",
      "ai/TASKS/archive/**"
    ]
  },
  "environment": {
    "language": "TypeScript",
    "runtime": "Node.js",
    "packageManager": "npm",
    "testFramework": "Jest"
  },
  "commands": {
    "test": "npm test",
    "lint": "npm run lint",
    "typecheck": "npm run typecheck",
    "build": "npm run build",
    "format": "npm run format:check"
  },
  "verification": {
    "requiredCoverage": null,
    "blockOnTodo": false,
    "blockOnConsole": true,
    "srcDir": "src",
    "timeoutSeconds": 300
  },
  "hints": {
    "alwaysReadFirst": [
      "CLAUDE.md",
      "ai/DEFINITIONS/DONE_DEFINITION.md"
    ],
    "readOnceAtTaskStart": [
      "docs/TECH_SPEC.md",
      "docs/ARCHITECTURE.md",
      "docs/ANTI_PATTERNS.md",
      "docs/PRD.md",
      "ai/CONTEXT.md",
      "tests/README.md"
    ],
    "beforeArchiving": [
      "Run src/scripts/verify-task.sh",
      "Check all CHECKLIST.md items complete",
      "Create ADR if architectural decisions made",
      "Update IMPLEMENTATION_PLAN.md status to DONE"
    ]
  },
  "scopeControl": {
    "enforceOneTaskAtATime": true,
    "requireVerificationBeforeDone": true,
    "blockMultipleActiveTasks": true,
    "activeTaskLocation": "root",
    "archiveLocation": "ai/TASKS/archive/"
  },
  "examples": {
    "_note": "Copy the relevant commands/verification blocks above for your stack",
    "python": {
      "commands": {
        "test": "pytest",
        "lint": "ruff check .",
        "typecheck": "mypy .",
        "build": "python -m build",
        "format": "ruff format --check ."
      },
      "verification": { "srcDir": "src" }
    },
    "go": {
      "commands": {
        "test": "go test ./...",
        "lint": "golangci-lint run",
        "typecheck": "go vet ./...",
        "build": "go build ./...",
        "format": "gofmt -l ."
      },
      "verification": { "srcDir": "." }
    },
    "rust": {
      "commands": {
        "test": "cargo test",
        "lint": "cargo clippy -- -D warnings",
        "typecheck": "cargo check",
        "build": "cargo build",
        "format": "cargo fmt -- --check"
      },
      "verification": { "srcDir": "src" }
    }
  }
}
